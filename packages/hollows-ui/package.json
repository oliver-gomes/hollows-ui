{
  "name": "hollows-ui",
  "version": "0.1.1",
  "description": "Auto-generated empty states for your UI",
  "homepage": "https://web-iota-seven-24.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliver-gomes/hollows-ui.git",
    "directory": "packages/hollows-ui"
  },
  "bugs": {
    "url": "https://github.com/oliver-gomes/hollows-ui/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "hollows-ui": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/adapters/react.mjs",
      "require": "./dist/adapters/react.js",
      "types": "./dist/adapters/react.d.ts"
    },
    "./vue": {
      "import": "./dist/adapters/vue.mjs",
      "require": "./dist/adapters/vue.js",
      "types": "./dist/adapters/vue.d.ts"
    },
    "./svelte": {
      "import": "./dist/adapters/svelte.mjs",
      "require": "./dist/adapters/svelte.js",
      "types": "./dist/adapters/svelte.d.ts"
    },
    "./illustrations/*": {
      "import": "./dist/illustrations/*.mjs",
      "require": "./dist/illustrations/*.js"
    }
  },
  "files": [
    "dist",
    "hollows.config.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "empty-states",
    "ui",
    "react",
    "vue",
    "svelte",
    "angular",
    "placeholder",
    "skeleton",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "@swc/core": "^1.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ora": "^8.0.0",
    "playwright": "^1.42.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
